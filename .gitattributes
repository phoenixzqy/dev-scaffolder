# Normalize line endings so Windows checkouts don't show phantom diffs.
# Default: let git decide, but always commit LF.
* text=auto eol=lf

# Shell scripts and Python must stay LF (they run on macOS/Linux).
*.sh   text eol=lf
*.bash text eol=lf
*.py   text eol=lf
*.zsh  text eol=lf

# Windows-only scripts use CRLF.
*.ps1  text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Binary assets — never touch.
*.png  binary
*.ttf  binary
*.otf  binary
*.zip  binary
*.ico  binary
